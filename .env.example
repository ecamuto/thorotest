# ─── Database ────────────────────────────────────────────────────────────────
# Default: SQLite (no extra setup)
DATABASE_URL=sqlite:///./testhub.db

# PostgreSQL
# DATABASE_URL=postgresql://thorotest:thorotest@localhost:5432/thorotest

# MySQL / MariaDB
# DATABASE_URL=mysql+pymysql://thorotest:thorotest@localhost:3306/thorotest

# ─── Security ─────────────────────────────────────────────────────────────────
# Set ENVIRONMENT=production to enforce prod safety checks (e.g. refuse to boot
# with the default SECRET_KEY below). Leave unset/empty for local dev.
# ENVIRONMENT=production
#
# Generate a strong random key for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# With ENVIRONMENT=production the app refuses to start if this is left as-is.
SECRET_KEY=thorotest-dev-secret-change-in-production

# CORS allowed origins. Comma-separated list, or "*" for any (dev only).
# Defaults to TESTHUB_BASE_URL when unset (correct for same-origin deploys).
# ALLOWED_ORIGINS=https://demo.example.com

# ─── First-boot admin ─────────────────────────────────────────────────────────
# Password for the seeded admin@localhost account on a fresh install. When
# unset, a random password is generated and printed ONCE in the server log
# (under DEMO_MODE the demo default "admin" is used instead).
# ADMIN_INITIAL_PASSWORD=

# ─── Demo mode ────────────────────────────────────────────────────────────────
# When enabled, opening a running run's live view drives it to completion with
# randomly generated results (for demos/screenshots only). Fabricates data —
# never enable in production; the app refuses to boot if ENVIRONMENT=production.
# DEMO_MODE=1

# ─── System email (password reset) ───────────────────────────────────────────
# Outbound SMTP for account emails. Unset SMTP_HOST = password-reset emails are
# skipped (the API still responds normally; nothing is leaked to the client).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Sender address (defaults to SMTP_USER):
SMTP_FROM=
# STARTTLS is on by default for port 587; port 465 uses implicit TLS.
# SMTP_STARTTLS=0

# ─── OAuth — Phase 14 ─────────────────────────────────────────────────────────
# Public base URL (must match provider callback registrations):
TESTHUB_BASE_URL=http://localhost:8000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth App callback URL (register in GitHub Developer settings):
#   {TESTHUB_BASE_URL}/api/auth/oauth/github/callback
# Google OAuth client Authorized redirect URI (Google Cloud Console):
#   {TESTHUB_BASE_URL}/api/auth/oauth/google/callback

# Auto-sync all Jira integrations every N minutes (0 = disabled).
# Needs outbound reachability to Jira Cloud; no public endpoint required.
JIRA_AUTOSYNC_MINUTES=0
