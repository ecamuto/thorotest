# ─── Database ────────────────────────────────────────────────────────────────
# Default: SQLite (no extra setup)
DATABASE_URL=sqlite:///./testhub.db

# PostgreSQL
# DATABASE_URL=postgresql://thorotest:thorotest@localhost:5432/thorotest

# MySQL / MariaDB
# DATABASE_URL=mysql+pymysql://thorotest:thorotest@localhost:3306/thorotest

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong random key for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=thorotest-dev-secret-change-in-production

# CORS allowed origins. Comma-separated list, or "*" for any (dev only).
# Defaults to TESTHUB_BASE_URL when unset (correct for same-origin deploys).
# ALLOWED_ORIGINS=https://demo.example.com

# ─── OAuth — Phase 14 ─────────────────────────────────────────────────────────
# Public base URL (must match provider callback registrations):
TESTHUB_BASE_URL=http://localhost:8000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth App callback URL (register in GitHub Developer settings):
#   {TESTHUB_BASE_URL}/api/auth/oauth/github/callback
# Google OAuth client Authorized redirect URI (Google Cloud Console):
#   {TESTHUB_BASE_URL}/api/auth/oauth/google/callback
